rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow create: if request.auth != null && request.resource.data.hostUid == request.auth.uid;
      allow read: if request.auth != null;
      allow update: if request.auth != null && resource.data.hostUid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['ruleset']);
    }
    match /rooms/{roomId}/players/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.keys().hasOnly(['uid', 'displayName', 'role', 'joinedAt']);
    }
    match /roomCodes/{code} {
      allow create: if request.auth != null && request.resource.data.hostUid == request.auth.uid;
      allow read: if request.auth != null;
    }
    match /{document=**} { allow read, write: if false; }
  }
}
